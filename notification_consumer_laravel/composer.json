{
    "name": "topik-khusus/notification-consumer-laravel",
    "description": "Notification Consumer Service built with Laravel and RabbitMQ",
    "type": "project",
    "require": {
        "php": "^8.0",
        "php-amqplib/php-amqplib": "^3.0"
    },
    "require-dev": {
        "laravel/tinker": "^2.0",
        "phpunit/phpunit": "^11.0"
    },
    "autoload": {
        "psr-4": {
            "App\\": "app/",
            "Database\\Factories\\": "database/factories/",
            "Database\\Seeders\\": "database/seeders/"
        }
    },
    "config": {
        "platform-check": false
    },
    "prefer-stable": true,
    "minimum-stability": "stable"
}
